generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?

  refreshTokens RefreshToken[]

  paperOrders    PaperOrder[]
  paperPositions PaperPosition[]

  strategies Strategy[]

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  brokerAccounts BrokerAccount[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model BrokerAccount {
  id String @id @default(cuid())

  broker   String
  clientId String @map("client_id")

  apiKey String? @map("api_key")

  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  feedToken    String? @map("feed_token")

  sessionSid     String? @map("session_sid")
  sessionBaseUrl String? @map("session_base_url")

  tokenExpiresAt DateTime? @map("token_expires_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@unique([userId, broker, clientId])
  @@map("broker_accounts")
}

enum PaperOrderSide {
  BUY
  SELL
}

enum PaperOrderStatus {
  FILLED
  CANCELLED
}

enum PaperPositionStatus {
  OPEN
  CLOSED
}

enum PaperInstrumentType {
  EQUITY
  FUTURE
  OPTION
}

enum PaperPositionSide {
  LONG
  SHORT
}

model PaperOrder {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  strategyId String? @map("strategy_id")

  brokerAccountId String? @map("broker_account_id")

  instrumentType PaperInstrumentType @map("instrument_type")

  token  String
  symbol String

  exchangeType Int    @map("exchange_type")
  exchange     String

  side PaperOrderSide

  quantity Int
  price    Float

  status PaperOrderStatus @default(FILLED)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("paper_orders")
}

model PaperPosition {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  strategyId String? @map("strategy_id")

  brokerAccountId String? @map("broker_account_id")

  instrumentType PaperInstrumentType @map("instrument_type")

  token  String
  symbol String

  exchangeType Int    @map("exchange_type")
  exchange     String

  quantity Int
  avgPrice Float @map("avg_price")

  status PaperPositionStatus @default(OPEN)

  side PaperPositionSide @default(LONG)

  realizedPnl Float @default(0) @map("realized_pnl")

  openedAt DateTime  @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([token])
  @@map("paper_positions")
}

enum StrategyStatus {
  STOPPED
  RUNNING
}

enum StrategyMode {
  PAPER
  LIVE
}

enum StrategyInstrumentType {
  EQUITY
  FUTURE
  OPTION
}

model Strategy {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brokerAccountId String? @map("broker_account_id")

  name String

  symbol String

  state Json?

  strategyType String @default("PRICE_BREAKOUT") @map("strategy_type")

  instrumentType StrategyInstrumentType @map("instrument_type")

  mode StrategyMode @default(PAPER)

  status StrategyStatus @default(STOPPED)

  rules Json
  trade Json
  risk  Json?

  lastTriggeredAt DateTime? @map("last_triggered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs StrategyLog[]

  @@index([userId])
  @@index([status])
  @@map("strategies")
}

model StrategyLog {
  id String @id @default(cuid())

  strategyId String   @map("strategy_id")
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  message String
  meta    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([strategyId])
  @@map("strategy_logs")
}
